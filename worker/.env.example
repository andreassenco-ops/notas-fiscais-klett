# ==============================================
# Klett Whats Sender - Variáveis de Ambiente
# Copie para .env e preencha os valores
# ==============================================

# Supabase (obrigatório)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1...

# SQL Server - Autolac (REMOTO - nuvem do Autolac)
SQLSERVER_HOST=<IP_OU_HOST_FORNECIDO_PELO_AUTOLAC>
SQLSERVER_PORT=1433
SQLSERVER_DB=Autolac
SQLSERVER_USER=<USUARIO_DE_CONSULTA>
SQLSERVER_PASS=<SENHA_DE_CONSULTA>

# Timezone
TZ=America/Sao_Paulo

# Janela de envio (padrão, pode ser alterado no painel)
SEND_WINDOW_START=06:00
SEND_WINDOW_END=21:00

# Delay entre envios em segundos (padrão)
DELAY_MIN=50
DELAY_MAX=130

# Concorrência (sempre 1 para manter ordem)
WORKER_CONCURRENCY=1
